# ============================================================================
# OIL AMOR - ENTERPRISE ENVIRONMENT CONFIGURATION
# Copy this file to .env.local and fill in your actual values
# ============================================================================

# =============================================================================
# SANITY CMS CONFIGURATION
# =============================================================================
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2023-05-03
SANITY_API_TOKEN=your-sanity-token
SANITY_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# DATABASE CONFIGURATION (Neon PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://user:password@host/database
DATABASE_URL_UNPOOLED=postgresql://user:password@host/database?sslmode=require

# =============================================================================
# REDIS CONFIGURATION (Upstash) - REQUIRED for rate limiting & sessions
# =============================================================================
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-characters-long
NEXTAUTH_URL=http://localhost:3000

# CSRF Token Secret (generate a strong random string)
CSRF_TOKEN_SECRET=your-csrf-secret-min-32-characters

# JWT Signing Secret
JWT_SECRET=your-jwt-secret-min-32-characters-long

# =============================================================================
# SENTRY ERROR TRACKING & PERFORMANCE MONITORING
# =============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_CSP_REPORT_URI=https://your-sentry-csp-endpoint
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0

# =============================================================================
# GOOGLE ANALYTICS & TAG MANAGER
# =============================================================================
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# =============================================================================
# FACEBOOK PIXEL (FOR RETARGETING)
# =============================================================================
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=XXXXXXXXXX

# =============================================================================
# HOTJAR / FULLSTORY (UX ANALYTICS) - CHOOSE ONE
# =============================================================================
NEXT_PUBLIC_HOTJAR_ID=XXXXXXX
NEXT_PUBLIC_HOTJAR_SNIPPET_VERSION=6
# OR
NEXT_PUBLIC_FULLSTORY_ORG_ID=XXXXX

# =============================================================================
# EMAIL SERVICE (Resend / SendGrid / Postmark)
# =============================================================================
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM_DOMAIN=oilamor.com
EMAIL_FROM_NAME="Oil Amor"

# =============================================================================
# PAYMENT PROCESSING (STRIPE)
# =============================================================================
# Get your keys from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Stripe Price IDs (create these in your Stripe Dashboard)
STRIPE_SHIPPING_STANDARD_PRICE_ID=price_xxxxxxxx
STRIPE_SHIPPING_EXPRESS_PRICE_ID=price_xxxxxxxx

# =============================================================================
# SHIPPING & LOGISTICS
# =============================================================================
AUSTRALIA_POST_API_KEY=your-auspost-api-key
AUSTRALIA_POST_API_SECRET=your-auspost-api-secret

# =============================================================================
# FEATURE FLAGS
# =============================================================================
NEXT_PUBLIC_ENABLE_REFILL_PROGRAM=true
NEXT_PUBLIC_ENABLE_CRYSTAL_CIRCLE=true
NEXT_PUBLIC_ENABLE_BULK_ORDERS=true
NEXT_PUBLIC_MAINTENANCE_MODE=false

# =============================================================================
# PERFORMANCE & CACHE
# =============================================================================
# Cache duration in seconds
API_CACHE_DURATION=300
STATIC_PAGE_CACHE_DURATION=60

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================
# Skip build type checking (faster builds, use with caution)
SKIP_TYPE_CHECK=false

# Enable React Strict Mode
NEXT_TELEMETRY_DISABLED=1
