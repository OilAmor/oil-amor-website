{
  "name": "oil-amor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "test:smoke": "playwright test",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:create": "tsx scripts/migrate.ts create",
    "migrate:status": "tsx scripts/migrate.ts status",
    "seed": "tsx scripts/seed-database.ts",
    "seed:shopify": "tsx scripts/seed-shopify.ts",
    "deploy": "./scripts/deploy.sh",
    "verify:env": "tsx scripts/verify-env.ts",
    "verify:all": "tsx scripts/verify-all.ts",
    "verify:shopify": "tsx scripts/verify-shopify.ts",
    "verify:sanity": "tsx scripts/verify-sanity.ts",
    "verify:redis": "tsx scripts/verify-redis.ts",
    "verify:auspost": "tsx scripts/verify-auspost.ts",
    "ops:health": "curl -s https://oilamor.com/api/health | jq",
    "ops:errors": "vercel logs oil-amor --production",
    "ops:cache-stats": "tsx scripts/cache-stats.ts",
    "ops:orders": "tsx scripts/order-stats.ts",
    "sync:inventory": "curl -X POST https://oilamor.com/api/cron/sync-inventory",
    "sync:tracking": "tsx scripts/sync-tracking.ts",
    "health": "curl https://oilamor.com/api/health"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-tabs": "^1.1.0",
    "@sanity/client": "^6.21.3",
    "@sanity/image-url": "^1.0.2",
    "@sentry/nextjs": "^8.27.0",
    "@upstash/redis": "^1.34.0",
    "@vercel/analytics": "^1.3.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.33.0",
    "framer-motion": "^11.3.30",
    "next": "15.0.0",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "drizzle-kit": "^0.24.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vercel": "^37.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.6.0"
}
